# ──────────────────────────────────────────────────────────────────────────
# DAM Platform — environment configuration
# Copy to .env and adjust. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────

# ---- Postgres (system of record) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dam
POSTGRES_USER=dam
POSTGRES_PASSWORD=dam_dev_pw
# SQLAlchemy async URL (used by the API). Host = "postgres" when running in compose.
DATABASE_URL=postgresql+asyncpg://dam:dam_dev_pw@localhost:5432/dam

# ---- Qdrant (vector store) ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- OpenSearch (keyword / metadata / timed transcript) ----
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=

# ---- Redis (queue + cache) ----
REDIS_URL=redis://localhost:6379/0

# ---- MinIO / S3 (object storage) ----
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dam-assets
S3_REGION=us-east-1
S3_SECURE=false

# ---- Auth ----
JWT_SECRET=change-me-in-prod-please
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=720

# ---- AI / models ----
# Keep model weights OFF the system drive and off the full D: drive.
HF_HOME=E:/dam-platform/.data/hf-cache
TORCH_HOME=E:/dam-platform/.data/torch-cache
# Device: cuda | cpu  (RTX 4000 Ada -> cuda)
AI_DEVICE=cuda
# Embedding models. RESIDENT (always loaded): text + image + reranker.
TEXT_EMBED_MODEL=BAAI/bge-m3                       # multilingual text (BGE-M3)
IMAGE_EMBED_MODEL=google/siglip2-base-patch16-512  # SigLIP 2 (multilingual image↔text)
RERANK_MODEL=BAAI/bge-reranker-v2-m3               # multilingual cross-encoder reranker
# ASR (P2) — on-demand, evicted after use
ASR_MODEL=large-v3
ASR_COMPUTE_TYPE=float16
# YOLOv11 object detection (on-demand)
YOLO_MODEL=yolo11n.pt
YOLO_DEVICE=cuda
# HF token for gated models (pyannote diarization, some weights)
HUGGINGFACE_TOKEN=

# ---- App ----
API_PORT=8000
WEB_PORT=3000
LOG_LEVEL=INFO
ENVIRONMENT=development
